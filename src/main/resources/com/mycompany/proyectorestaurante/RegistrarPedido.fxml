<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="485.0" prefWidth="382.0" style="-fx-background-color: #1B4D56;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.proyectorestaurante.controlador.RegistrarPedidoController">
   <children>
      <Label layoutX="114.0" layoutY="14.0" text="Restaurante" textAlignment="CENTER" textFill="#efefe8">
         <font>
            <Font name="System Bold" size="27.0" />
         </font>
      </Label>
      <Label layoutX="218.0" layoutY="53.0" text="TAL" textAlignment="CENTER" textFill="#efefe8">
         <font>
            <Font name="System Bold" size="27.0" />
         </font>
      </Label>
      <VBox alignment="TOP_CENTER" layoutY="125.0" prefHeight="370.0" prefWidth="382.0" style="-fx-background-color: #f5efe6; -fx-background-radius: 10; -fx-spacing: 15;">
         <children>
            <HBox alignment="TOP_CENTER" prefHeight="59.0" prefWidth="382.0">
               <children>
                  <Label text="Resumen del pedido">
                     <font>
                        <Font name="System Bold" size="16.0" />
                     </font></Label>
               </children>
            </HBox>
            <TableView fx:id="TablaDePedido" prefHeight="200.0" prefWidth="200.0" style="-fx-background-color: transparent; -fx-border-color: transparent;">
              <columns>
                <TableColumn fx:id="colNombre" prefWidth="75.0" text="Nombre" />
                <TableColumn fx:id="colCantidad" prefWidth="75.0" text="Cantidad" />
              </columns>
            </TableView>
            <HBox alignment="TOP_RIGHT" prefHeight="27.0" prefWidth="382.0">
               <children>
                  <Label fx:id="lblTotal" text="Total acomulado:" />
               </children>
            </HBox>
            <TextField fx:id="txtNombreProducto" onAction="#AgregarProductoBuscado" />
            <HBox prefHeight="100.0" prefWidth="200.0">
               <children>
                  <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0">
                     <children>
                        <Button fx:id="btnVolver" mnemonicParsing="false" onAction="#Volver" style="-fx-background-radius: 20; -fx-padding: 10 20;" text="Volver">
                           <font>
                              <Font size="10.0" />
                           </font>
                        </Button>
                     </children>
                  </HBox>
                  <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0">
                     <children>
                        <Button fx:id="btnTerminarPedido" mnemonicParsing="false" onAction="#EnviarACocina" style="-fx-background-radius: 20; -fx-padding: 10 20;" text="Terminar Pedido">
                           <font>
                              <Font size="10.0" />
                           </font>
                        </Button>
                     </children>
                  </HBox>
                  <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0">
                     <children>
                        <Button fx:id="btnAgregarAPedido" mnemonicParsing="false" onAction="#AgregarProductoBuscado" style="-fx-background-radius: 20; -fx-padding: 10 20;" text="Agregar Producto">
                           <font>
                              <Font size="10.0" />
                           </font>
                        </Button>
                     </children>
                  </HBox>
               </children>
            </HBox>
         </children></VBox>
   </children>
</AnchorPane>
